DATABASE_URL=sqlite:///./backend.db
JWT_SECRET_KEY=change-this-for-local-dev
FRONTEND_URL=http://localhost:3000
POSE_BACKEND=mediapipe

# Optional Google login
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional SMTP email. If missing, auth emails are printed in backend terminal.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=GymFixer
SMTP_USE_TLS=true

# Optional Gemini coaching
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro
GEMINI_MAX_OUTPUT_TOKENS=3000
POSTURE_LLM_MAX_LOG_FRAMES=300

# Pose/session analysis
POSTURE_SUBJECT_READY_MIN_FRAMES=10
POSTURE_SUBJECT_MIN_BBOX_AREA=0.035
POSTURE_SUBJECT_MIN_BBOX_WIDTH=0.12
POSTURE_SUBJECT_MIN_BBOX_HEIGHT=0.20
MP_MIN_DET_CONF=0.5
MP_MIN_TRACK_CONF=0.5
MP_VIS_THRESHOLD=0.5
